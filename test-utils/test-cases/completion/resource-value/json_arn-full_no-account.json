---
excludes:
  - "arn:aws:s3:us-east-1::accesspoint/${AccessPointName}"
  - "arn:aws:s3:::${BucketName}"
  - "arn:aws:s3::123456789012:accesspoint/${AccessPointAlias}"
---
{
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": [
        "arn:aws:s3:us-east-1::$0
      ]
    }
  ]
}
