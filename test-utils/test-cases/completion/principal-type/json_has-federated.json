---
includes:
  - AWS
  - Service
  - CanonicalUser
excludes:
  - Federated
  - "cognito-identity.amazonaws.com"
  - "lambda.amazonaws.com"
---
{
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "*",
      "Principal": {
        "Federated": ["cognito-identity.amazonaws.com"],
        "$0"
      }
    }
  ]
}
